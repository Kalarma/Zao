  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --white:    #ffffff;
      --bg:       #f5f4f2;
      --surface:  #ffffff;
      --border:   #e8e4de;
      --border2:  #d5cfc6;
      --text:     #1a1816;
      --text2:    #5a5450;
      --text3:    #9a938a;
      --accent:   #2c5282;
      --accent2:  #3a6ea8;
      --tag-bg:   #eef2f8;
      --tag-text: #2c5282;
      --radius:   14px;
      --radius-sm:8px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-name {
      font-weight: 600;
      font-size: .95rem;
      color: var(--text);
      letter-spacing: -.01em;
    }
    .nav-links {
      display: flex;
      gap: 1.8rem;
      list-style: none;
    }
    .nav-links a {
      font-size: .85rem;
      font-weight: 500;
      color: var(--text2);
      text-decoration: none;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--accent); }
    @media (max-width: 560px) { .nav-links { display: none; } }

    /* ── HERO ── */
    .hero {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 5rem 2rem 4rem;
    }
    .hero-inner {
      max-width: 860px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3rem;
      align-items: center;
    }
    @media (max-width: 640px) {
      .hero-inner { grid-template-columns: 1fr; text-align: center; }
      .hero-contacts { justify-content: center !important; }
    }

    .avatar-wrap { position: relative; width: 130px; height: 130px; }
    .avatar-wrap img, .avatar-placeholder {
      width: 130px; height: 130px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--border);
      display: block;
      background: var(--bg);
    }
    .avatar-placeholder {
      display: flex; align-items: center; justify-content: center;
      font-size: 2.8rem;
    }
    .status-dot {
      position: absolute;
      bottom: 6px; right: 6px;
      width: 16px; height: 16px;
      background: #3da86a;
      border-radius: 50%;
      border: 2.5px solid white;
    }

    .hero-kicker {
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: .6rem;
    }
    h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.1;
      color: var(--text);
      margin-bottom: .8rem;
    }
    .hero-bio {
      font-size: 1rem;
      color: var(--text2);
      max-width: 520px;
      margin-bottom: 1.6rem;
    }
    .hero-contacts {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      padding: .38rem .9rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: .82rem;
      color: var(--text2);
      text-decoration: none;
      font-weight: 500;
      transition: border-color .2s, color .2s, background .2s;
    }
    .pill:hover { border-color: var(--accent2); color: var(--accent); background: var(--tag-bg); }

    /* ── MAIN LAYOUT ── */
    .container {
      max-width: 860px;
      margin: 0 auto;
      padding: 3.5rem 2rem 5rem;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 2.5rem;
      align-items: start;
    }
    @media (max-width: 780px) {
      .container { grid-template-columns: 1fr; }
      .sidebar { order: -1; }
    }

    /* ── CARDS ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.8rem;
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text3);
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: .7rem;
    }
    .section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── TIMELINE ── */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .tl-item {
      display: grid;
      grid-template-columns: 1px 1fr;
      gap: 0 1.4rem;
      position: relative;
      padding-bottom: 1.8rem;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity .45s, transform .45s;
    }
    .tl-item.visible { opacity: 1; transform: none; }
    .tl-item:last-child { padding-bottom: 0; }

    .tl-line {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .tl-dot {
      width: 10px; height: 10px;
      background: var(--accent);
      border-radius: 50%;
      border: 2px solid var(--white);
      box-shadow: 0 0 0 2px var(--accent);
      flex-shrink: 0;
      margin-top: 4px;
    }
    .tl-connector {
      flex: 1;
      width: 1px;
      background: var(--border2);
      margin-top: 4px;
    }
    .tl-item:last-child .tl-connector { display: none; }

    .tl-date {
      font-size: .75rem;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: .04em;
      margin-bottom: .15rem;
    }
    .tl-title {
      font-weight: 600;
      font-size: .97rem;
      color: var(--text);
      margin-bottom: .1rem;
      line-height: 1.3;
    }
    .tl-place {
      font-size: .83rem;
      color: var(--text3);
      margin-bottom: .6rem;
      font-style: italic;
    }
    .tl-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .25rem;
    }
    .tl-bullets li {
      font-size: .88rem;
      color: var(--text2);
      padding-left: 1rem;
      position: relative;
    }
    .tl-bullets li::before {
      content: '–';
      position: absolute;
      left: 0;
      color: var(--text3);
    }

    /* ── SIDEBAR CARDS ── */
    .info-list { display: flex; flex-direction: column; gap: .85rem; }
    .info-row {
      display: flex;
      align-items: flex-start;
      gap: .8rem;
      font-size: .9rem;
    }
    .info-icon {
      width: 32px; height: 32px;
      border-radius: var(--radius-sm);
      background: var(--tag-bg);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: .9rem;
      flex-shrink: 0;
    }
    .info-label { font-size: .73rem; color: var(--text3); line-height: 1.2; }
    .info-value { font-weight: 500; color: var(--text); line-height: 1.3; font-size: .9rem; }
    .info-value a { color: var(--accent); text-decoration: none; }
    .info-value a:hover { text-decoration: underline; }

    /* ── TAGS ── */
    .tag-cloud { display: flex; flex-wrap: wrap; gap: .5rem; }
    .tag {
      display: inline-block;
      padding: .3rem .75rem;
      background: var(--tag-bg);
      border: 1px solid #d4e0f0;
      color: var(--tag-text);
      border-radius: 999px;
      font-size: .8rem;
      font-weight: 500;
    }
    .tag.green {
      background: #edf7f2;
      border-color: #b8e0cc;
      color: #276749;
    }
    .tag.gray {
      background: var(--bg);
      border-color: var(--border2);
      color: var(--text2);
    }

    /* ── ALTERNANCE BANNER ── */
