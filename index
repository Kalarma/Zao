    .alternance-banner .icon { font-size: 1.3rem; }
    .alternance-banner strong { font-size: .88rem; color: var(--accent); display: block; margin-bottom: .1rem; }
    .alternance-banner span { font-size: .8rem; color: var(--text2); }

    /* ── PASSIONS ── */
    .passion-grid { display: flex; flex-direction: column; gap: .75rem; }
    .passion-item {
      display: flex;
      align-items: flex-start;
      gap: .9rem;
      padding: .9rem 1rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
    }
    .passion-icon { font-size: 1.3rem; line-height: 1; margin-top: .1rem; }
    .passion-item h4 { font-weight: 600; font-size: .9rem; color: var(--text); margin-bottom: .15rem; }
    .passion-item p { font-size: .82rem; color: var(--text2); }

    /* ── FOOTER ── */
