      border-top: 1px solid var(--border);
      padding: 2.5rem 2rem;
      text-align: center;
    }
    footer p { font-size: .82rem; color: var(--text3); }
    footer strong { color: var(--text); font-weight: 600; }

    /* ── UTILS ── */
    .mb-0 { margin-bottom: 0 !important; }
  </style>
</head>
